{
  "version": 2,
  "installCommand": "npm install --production=false",
  "buildCommand": "npx prisma generate && npx tsc -p tsconfig.json",
  "outputDirectory": ".",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api" }
  ]
}
